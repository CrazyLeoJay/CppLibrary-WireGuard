{
  "module": {
    "name": "wg_tunnel",
    "type": "har",
    "deviceTypes": [
      "default",
      "tablet"
    ],
    "routerMap": '$profile:router_map',
    "abilities": [
    ],
    "extensionAbilities": [
      {
        "name": "WGVpnExtAbility",
        "srcEntry": "./ets/ability/WGVpnExtAbility.ets",
        "type": "vpn",
      }
    ],
    "requestPermissions": [
      {
        "name": "ohos.permission.INTERNET",
        "reason": "$string:perm_reason_internet"
      }
    ]
  }
}
